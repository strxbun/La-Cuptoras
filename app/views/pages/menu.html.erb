    <style>
        /* Stiluri pentru selectorul de limbă */
        .language-switcher {
            display: flex;
            gap: 5px;
            margin-left: 15px;
        }

        .language-switcher button {
            background-color: #6995db;
            color: #fff;
            border: none;
            padding: 8px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: background-color 0.3s ease;
        }

        .language-switcher button:hover {
            background-color: #b3cbee;
        }

        .language-switcher button.active {
            background-color: #0F172B;
            border: 1px solid #6995db;
        }
    </style>
</head>

