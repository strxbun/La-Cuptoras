<div class="bg-white p-0">
  <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
      <span class="sr-only" data-lang-key="loading">Loading...</span>
    </div>
  </div>

  <div class="container-xxl position-relative p-0">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4 px-lg-5 py-3 py-lg-0">
      <%= link_to root_path, class: "navbar-brand p-0" do %>
        <h1 class="text-primary m-0" data-lang-key="brand-name">
          <i class="fa fa-utensils me-3"></i>La Cuptoraș
        </h1>
      <% end %>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="fa fa-bars"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto py-0 pe-4">
          <%= link_to "Acasă", root_path, class: "nav-item nav-link active", data: { lang_key: "home" } %>
          <%= link_to "Despre Noi", about_path, class: "nav-item nav-link", data: { lang_key: "about-us" } %>
          <%= link_to "Meniu", menu_path, class: "nav-item nav-link", data: { lang_key: "menu" } %>
          <%= link_to "Contacte", contact_path, class: "nav-item nav-link", data: { lang_key: "contact" } %>
        </div>

        <div class="language-switcher">
          <button id="lang-ro" class="active" type="button">RO</button>
          <button id="lang-ru" type="button">RU</button>
        </div>
      </div>
    </nav>

    <div class="container-xxl py-5 bg-dark hero-header mb-5">
      <div class="container my-5 py-5">
        <div class="row align-items-center g-5">
          <div class="col-lg-6 text-center text-lg-start">
            <h1 class="display-3 text-white animated slideInLeft" data-lang-key="hero-title">
              Ca la mama acasă<br>în bucătăria noastră
            </h1>
            <p class="text-white animated slideInLeft mb-4 pb-2" data-lang-key="hero-subtitle">
              La Cuptoraș, servicii de catering și restaurant cu mâncare tradițională.
            </p>
          </div>

          <div class="col-lg-6 text-center text-lg-end overflow-hidden">
            <%= image_tag "hero.png", class: "img-fluid", alt: "" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xxl py-5">
    <div class="container">
      <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.3s">
          <div class="service-item rounded pt-3">
            <div class="p-4">
              <i class="fa fa-3x fa-utensils text-primary mb-4"></i>
              <h5 data-lang-key="service1-title">Mâncare de calitate superioara</h5>
              <p data-lang-key="service1-description">
                Pregătim mâncarea doar din produse proaspete, și de către bucătari profesioniști.
              </p>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.5s">
          <div class="service-item rounded pt-3">
            <div class="p-4 justify-content-center">
              <i class="fa fa-3x fa-cart-plus text-primary mb-4"></i>
              <h5 data-lang-key="service2-title">Comandă online</h5>
              <p data-lang-key="service2-description">
                Oferim livrarea produselor din restaurant și servicii de catering la comandă pentru orice fel de eveniment.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xxl py-5">
    <div class="container">
      <div class="row g-5 align-items-center">
        <div class="col-lg-6">
          <div class="row g-3">
            <div class="col-6 text-start">
              <%= image_tag "about-1.jpg", class: "img-fluid rounded w-100 wow zoomIn", alt: "" %>
            </div>
            <div class="col-6 text-start">
              <%= image_tag "about-2.jpg", class: "img-fluid rounded w-75 wow zoomIn", alt: "", style: "margin-top: 25%;" %>
            </div>
            <div class="col-6 text-end">
              <%= image_tag "about-3.jpg", class: "img-fluid rounded w-75 wow zoomIn", alt: "" %>
            </div>
            <div class="col-6 text-end">
              <%= image_tag "about-4.jpg", class: "img-fluid rounded w-100 wow zoomIn", alt: "" %>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <h5 class="section-title ff-secondary text-start text-primary fw-normal" data-lang-key="about-section-title">Despre Noi</h5>
          <h1 class="mb-4" data-lang-key="about-welcome-title">
            Bun venit <i class="fa fa-utensils text-primary me-2"></i>La Cuptoraș
          </h1>
          <p class="mb-4" data-lang-key="about-description1">
            La Cuptoraș este un local dedicat preparatelor tradiționale românești, oferind atât servire în restaurant, cât și servicii profesionale de catering.
          </p>
          <p class="mb-4" data-lang-key="about-description2">
            Ne remarcăm prin atenția la detalii, calitatea ingredientelor și respectul pentru rețetele autentice. Fie că vrei o masă delicioasă în oraș sau bucate alese livrate direct la evenimentul tău, La Cuptoraș este alegerea ideală.
          </p>

          <div class="row g-4 mb-4">
            <div class="col-sm-6">
              <div class="d-flex align-items-center border-start border-5 border-primary px-3">
                <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">13</h1>
                <div class="ps-4">
                  <p class="mb-0" data-lang-key="experience-years-text">Ani de</p>
                  <h6 class="text-uppercase mb-0" data-lang-key="experience-title">Experiență</h6>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>    
    </div>
  </div>

  <div class="container-xxl py-5">
    <div class="container">
      <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
        <h5 class="section-title ff-secondary text-center text-primary fw-normal" data-lang-key="menu-section-title">Meniu</h5>
        <h1 class="mb-5" data-lang-key="menu-tagline">Dacă e bun, se va dori o a 2-a porție</h1>
      </div>

      <div class="row g-4">
        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-1.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="pancakes-title">Pancakes</span>
                <span class="text-primary">70 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="pancakes-description">
                Pancakes, frișcă, stafide, pomușoare, vanilie, zahăr, miere, ulei de floarea soarelui.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-2.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="guguta-title">Cușma lui Guguță</span>
                <span class="text-primary">130 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="guguta-description">
                Făină de grâu, chefir, ou de găină, lapte, zahăr de vanilie, ulei de floarea soarelui, vișină, smântână, zahăr, ciocolată rasă.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-3.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="mexican-solyanka-title">Soleancă Mexicană</span>
                <span class="text-primary">40 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="mexican-solyanka-description">
                Bulion, carne de vită, fasole, porumb, nachos, ardei, roșii, ceapă, usturoi, pătrunjel, condimente.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-4.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="caesar-salad-title">Salată Caesar</span>
                <span class="text-primary">125 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="caesar-salad-description">
                Salată iceberg, creveți, roșii, sos Caesar, pesmeți, ouă, parmezan, frunze de salată, condimente.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-5.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="cream-soup-title">Supă Cremă</span>
                <span class="text-primary">60 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="cream-soup-description">
                Bulion, frișcă, carne de pui, ciuperci, ceapă, pătrunjel, ulei de măsline, chiflă.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-6.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="baked-wings-title">Aripioare Coapte</span>
                <span class="text-primary">90 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="baked-wings-description">
                Aripioare de pui, sos picant, ketchup.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-7.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="sarmale-title">Sarmale/Ardei Umpluți</span>
                <span class="text-primary">110 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="sarmale-description">
                Varză, carne de porc, ceapă, morcov, roșii decojite, orez, ulei de floarea soarelui, condimente, sos din tomate cu ardei dulce, verdeață.
              </small>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="d-flex align-items-center">
            <%= image_tag "menu-8.jpg", class: "flex-shrink-0 img-fluid rounded", alt: "", style: "width: 80px;" %>
            <div class="w-100 d-flex flex-column text-start ps-4">
              <h5 class="d-flex justify-content-between border-bottom pb-2">
                <span data-lang-key="crepes-title">Clătite Branză/Carne/Ciuperci</span>
                <span class="text-primary">90 LEI</span>
              </h5>
              <small class="fst-italic" data-lang-key="crepes-description">
                Carne de pui, ouă de găină, făină de grâu, lapte, ceapă, frișcă, cașcaval, unt, ulei de floarea soarelui, verdeață, condimente.
              </small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xxl pt-5 pb-3">
    <div class="container">
      <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
        <h5 class="section-title ff-secondary text-center text-primary fw-normal" data-lang-key="testimonial-section-title">Recenzii</h5>
        <h1 class="mb-5" data-lang-key="testimonial-main-title">Clienții noștrii!!!</h1>
      </div>

      <div class="owl-carousel testimonial-carousel">
        <div class="testimonial-item bg-transparent border rounded p-4">
          <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
          <p data-lang-key="testimonial1-text">
            Am avut o experiență foarte plăcută. Atmosfera este primitoare, mâncarea delicioasă. Totul a fost impecabil.
          </p>
          <div class="d-flex align-items-center">
            <%= image_tag "testimonial-1.jpg", class: "img-fluid flex-shrink-0 rounded-circle", alt: "", style: "width: 50px; height: 50px;" %>
            <div class="ps-3">
              <h5 class="mb-1" data-lang-key="testimonial1-name">Alexandra</h5>
            </div>
          </div>
        </div>

        <div class="testimonial-item bg-transparent border rounded p-4">
          <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
          <p data-lang-key="testimonial2-text">
            Foarte plăcută atmosfera din local. Angajații foarte amabili, am avut un timp frumos cu familia. Recomand!
          </p>
          <div class="d-flex align-items-center">
            <%= image_tag "testimonial-2.jpg", class: "img-fluid flex-shrink-0 rounded-circle", alt: "", style: "width: 50px; height: 50px;" %>
            <div class="ps-3">
              <h5 class="mb-1" data-lang-key="testimonial2-name">Andrei</h5>
            </div>
          </div>
        </div>

        <div class="testimonial-item bg-transparent border rounded p-4">
          <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
          <p data-lang-key="testimonial3-text">
            O seară foarte plăcută. Atmosfera binevoitoare, mâncarea foarte gustoasă, personalul politicos. La sigur o să mai revenim în acest local.
          </p>
          <div class="d-flex align-items-center">
            <%= image_tag "testimonial-3.jpg", class: "img-fluid flex-shrink-0 rounded-circle", alt: "", style: "width: 50px; height: 50px;" %>
            <div class="ps-3">
              <h5 class="mb-1" data-lang-key="testimonial3-name">Eugeniu</h5>
            </div>
          </div>
        </div>

        <div class="testimonial-item bg-transparent border rounded p-4">
          <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
          <p data-lang-key="testimonial4-text">
            Totul a fost foarte bun, am avut o mică neplăcere, dar administratorul a lămurit frumos situația. Mulțumesc.
          </p>
          <div class="d-flex align-items-center">
            <%= image_tag "testimonial-4.jpg", class: "img-fluid flex-shrink-0 rounded-circle", alt: "", style: "width: 50px; height: 50px;" %>
            <div class="ps-3">
              <h5 class="mb-1" data-lang-key="testimonial4-name">Daniela</h5>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container-fluid bg-dark text-light footer pt-5 mt-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container py-5">
      <div class="row g-5">
        <div class="col-lg-4 col-md-6">
          <h4 class="section-title ff-secondary text-start text-primary fw-normal mb-4" data-lang-key="footer-brand-name">La Cuptoraș</h4>
          <%= link_to "Despre Noi", about_path, class: "btn btn-link", data: { lang_key: "footer-about-us" } %>
          <%= link_to "Contacte", contact_path, class: "btn btn-link", data: { lang_key: "footer-contact" } %>
          <a class="btn btn-link" href="#" data-lang-key="privacy-policy">Politica Confidențialității</a>
          <a class="btn btn-link" href="#" data-lang-key="terms-conditions">Termeni și Condiții</a>
        </div>

        <div class="col-lg-4 col-md-6">
          <h4 class="section-title ff-secondary text-start text-primary fw-normal mb-4" data-lang-key="footer-contacts-title">Contacte</h4>
          <p class="mb-2"><i class="fa fa-map-marker-alt me-3"></i>Bd. Dacia 13, Chișinău, Republica Moldova</p>
          <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>+373 079 760 326</p>
          <p class="mb-2"><i class="fa fa-envelope me-3"></i>la.cuptoras@mail.ru</p>

          <div class="d-flex pt-2">
            <a class="btn btn-outline-light btn-social" href="#"><i class="fab fa-twitter"></i></a>
            <a class="btn btn-outline-light btn-social" href="#"><i class="fab fa-facebook-f"></i></a>
            <a class="btn btn-outline-light btn-social" href="#"><i class="fab fa-youtube"></i></a>
            <a class="btn btn-outline-light btn-social" href="#"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>

        <div class="col-lg-4 col-md-6">
          <h4 class="section-title ff-secondary text-start text-primary fw-normal mb-4" data-lang-key="opening-hours-title">Orele de lucru</h4>
          <h5 class="text-light fw-normal" data-lang-key="weekdays">Luni - Vineri</h5>
          <p>11:00 - 16:00</p>
          <h5 class="text-light fw-normal" data-lang-key="weekends">Sâmbăta - Duminica</h5>
          <p data-lang-key="days-off">Zile de odihnă</p>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="copyright">
        <div class="row">
          <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
            © <a class="border-bottom" href="#" data-lang-key="copyright-text">La cuptoraș 2025</a>,
            <span data-lang-key="all-rights-reserved">Toate drepturile rezervate.</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top">
    <i class="bi bi-arrow-up"></i>
  </a>
</div>